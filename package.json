{
  "name": "guitar-practice",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "vite build && gh-pages -d dist --nojekyll && node scripts/wait-for-deploy.js",
    "typecheck": "tsc --noEmit",
    "preview:test": "vite preview --port 4173 --strictPort",
    "test:e2e": "NODE_OPTIONS='--import tsx' cucumber-js",
    "test:e2e:audio": "NODE_OPTIONS='--import tsx' cucumber-js -p audio",
    "test": "npm run build && start-server-and-test preview:test http://localhost:4173/guitar-practice/ test:e2e",
    "test:dev": "BASE_URL=http://localhost:5173/guitar-practice/ start-server-and-test dev http://localhost:5173/guitar-practice/ test:e2e",
    "test:headed": "HEADLESS=false npm test",
    "test:audio": "npm run build && start-server-and-test preview:test http://localhost:4173/guitar-practice/ test:e2e:audio",
    "tones": "node tests/fixtures/gen-tones.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.9.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "playwright": "^1.60.0",
    "start-server-and-test": "^3.0.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0"
  }
}
